DATABASE_URL=postgresql+psycopg://USERNAME:PASSWORD@HOST:PORT/DATABASE

# Optional. Comma-separated list of allowed CORS origins. Whitespace around
# each entry is trimmed. Falls back to https://management-aios.vercel.app if
# unset. Localhost/127.0.0.1 (any port) is always allowed separately for
# local development — see backend/config.py.
ALLOWED_ORIGINS=https://management-aios.vercel.app

# Optional. Informational only; not currently used to change runtime
# behavior. Defaults to "development" if unset.
ENVIRONMENT=production
