.env
.env.*
!.env.example

# Python generated files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/
*.log

# Staff Data raw source — dashboard-specific staging area only (see
# member-aios/staff-data/README.md). HR-provided raw files are kept locally
# outside git; only the folder placeholder is tracked. Not a repository-wide
# *.pdf rule — scoped to this one directory.
member-aios/staff-data/source/raw/*
!member-aios/staff-data/source/raw/.gitkeep

# Real normalized HR staff data — local only
member-aios/staff-data/source/normalized/hr-staff-dashboard.csv

# Generated SQL import scripts contain real employee data (names, NIC
# values) as literal SQL text — local only, never committed. See
# scripts/import_staff_dashboard_csv.py --emit-sql.
member-aios/staff-data/source/normalized/*.sql

# HR-verified staff location reconciliation evidence — contains real
# database row UUIDs tied to real staff records; local-only report, never
# committed. See scripts/update_staff_locations_from_hr_sources.py and
# validation/staff-location-source-reconciliation-check-2026-07-13.md.
evidence/staff-location-update-reconciliation-*.csv
